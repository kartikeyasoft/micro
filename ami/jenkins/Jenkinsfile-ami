@Library('jenkins-shared-lib-deno@main') _

pipeline {
    agent any

    environment {
        // AWS Credentials
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        
        // Service Configuration
        SERVICE_NAME = 'ami'
        SERVICE_VERSION = "${env.BUILD_NUMBER}"
        
        // Additional Configuration
        CLEAN_WORKSPACE = 'true'
    }

    stages {
        stage('Initialize') {
            steps {
                script {
                    // Load configuration from shared library
                    def config = envConfig()
                    
                    // Set AWS configuration
                    env.AWS_DEFAULT_REGION = config.aws.region
                    env.BASE_AMI_ID = config.baseAmi.ubuntu2204
                    
                    // Print configuration
                    echo "=========================================="
                    echo "Pipeline Configuration"
                    echo "=========================================="
                    echo "Service Name: ${env.SERVICE_NAME}"
                    echo "Service Version: ${env.SERVICE_VERSION}"
                    echo "AWS Region: ${env.AWS_DEFAULT_REGION}"
                    echo "Base AMI ID: ${env.BASE_AMI_ID}"
                    echo "Build Number: ${env.BUILD_NUMBER}"
                    echo "=========================================="
                }
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
                
                script {
                    // Verify packer directory exists
                    if (!fileExists('ami/packer')) {
                        error "ami/packer directory not found in repository!"
                    }
                }
            }
        }

        stage('Prepare Packer Variables') {
            steps {
                script {
                    dir('ami/packer') {
                        // Create Packer auto-variables file - Fixed escaping
                        sh """
                            cat > variables.auto.pkrvars.hcl << 'EOF'
                            # Packer variables - Auto-generated by Jenkins
                            service_name     = "${env.SERVICE_NAME}"
                            service_version  = "${env.SERVICE_VERSION}"
                            source_ami       = "${env.BASE_AMI_ID}"
                            aws_region       = "${env.AWS_DEFAULT_REGION}"
                            EOF
                            
                            echo "Generated Packer variables file:"
                            cat variables.auto.pkrvars.hcl
                        """
                    }
                }
            }
        }

        stage('Validate Packer Template') {
            steps {
                script {
                    dir('ami/packer') {
                        sh """
                            echo "Initializing Packer..."
                            packer init ami.pkr.hcl
                            
                            echo "Validating Packer template..."
                            packer validate ami.pkr.hcl
                        """
                    }
                }
            }
        }

        stage('Build Custom AMI') {
            steps {
                script {
                    dir('ami/packer') {
                        sh """
                            echo "Building custom AMI..."
                            packer build \
                                -timestamp-ui \
                                ami.pkr.hcl 2>&1 | tee build-output.txt
                            
                            # Extract AMI ID from manifest or output
                            if [ -f manifest.json ]; then
                                AMI_ID=\$(jq -r '.builds[-1].artifact_id' manifest.json | cut -d: -f2)
                            else
                                AMI_ID=\$(grep -Eo 'ami-[a-f0-9]{8,}' build-output.txt | tail -1)
                            fi
                            
                            if [ -z "\$AMI_ID" ]; then
                                echo "ERROR: Failed to extract AMI ID"
                                exit 1
                            fi
                            
                            echo "CUSTOM_AMI_ID=\$AMI_ID" > custom-ami.properties
                            echo "AMI_ID=\$AMI_ID" >> custom-ami.properties
                            echo "Created AMI: \$AMI_ID"
                            
                            # Display AMI information
                            echo "AMI Details:"
                            echo "  ID: \$AMI_ID"
                            echo "  Name: ${env.SERVICE_NAME}-${env.SERVICE_VERSION}"
                            echo "  Region: ${env.AWS_DEFAULT_REGION}"
                        """
                        
                        // Read and store AMI ID
                        def amiProps = readFile('custom-ami.properties')
                        env.AMI_ID = amiProps.split('=')[1].trim().split('\\n')[0]
                        
                        // Stash AMI properties for later stages
                        stash name: 'ami-properties', includes: 'custom-ami.properties'
                        
                        echo "✅ Successfully created AMI: ${env.AMI_ID}"
                    }
                }
            }
        }

        stage('Tag AMI') {
            steps {
                script {
                    echo "Tagging AMI: ${env.AMI_ID}"
                    // Fixed: Escape all $ for shell variables, keep ${env.XXX} for Groovy
                    sh """
                        # Add standard tags
                        aws ec2 create-tags \
                            --resources ${env.AMI_ID} \
                            --region ${env.AWS_DEFAULT_REGION} \
                            --tags \
                                Key=Name,Value=${env.SERVICE_NAME}-v${env.SERVICE_VERSION} \
                                Key=Service,Value=${env.SERVICE_NAME} \
                                Key=Version,Value=${env.SERVICE_VERSION} \
                                Key=BuildNumber,Value=${env.BUILD_NUMBER} \
                                Key=SourceAMI,Value=${env.BASE_AMI_ID} \
                                Key=CreatedBy,Value=Jenkins \
                                Key=CreatedTime,Value=\$(date -u +%Y-%m-%dT%H:%M:%SZ) \
                                Key=Environment,Value=production \
                                Key=Organization,Value=myorg
                        
                        # Add environment-specific tags
                        aws ec2 create-tags \
                            --resources ${env.AMI_ID} \
                            --region ${env.AWS_DEFAULT_REGION} \
                            --tags \
                                Key=CostCenter,Value=engineering \
                                Key=AutoDelete,Value=false
                        
                        echo "✅ Successfully tagged AMI: ${env.AMI_ID}"
                    """
                }
            }
        }

        stage('Verify AMI') {
            steps {
                script {
                    echo "=========================================="
                    echo "AMI Verification"
                    echo "=========================================="
                    
                    // Check AMI state
                    def amiState = sh(script: """
                        aws ec2 describe-images \
                            --image-ids ${env.AMI_ID} \
                            --region ${env.AWS_DEFAULT_REGION} \
                            --query 'Images[0].State' \
                            --output text
                    """, returnStdout: true).trim()
                    
                    echo "AMI State: ${amiState}"
                    
                    if (amiState != 'available') {
                        error "AMI is not in available state! Current state: ${amiState}"
                    }
                    
                    // Check AMI tags - Fixed escaping
                    sh """
                        echo "AMI Tags:"
                        aws ec2 describe-tags \
                            --filters "Name=resource-id,Values=${env.AMI_ID}" \
                            --region ${env.AWS_DEFAULT_REGION} \
                            --query 'Tags[*].[Key,Value]' \
                            --output table
                    """
                    
                    echo "=========================================="
                    echo "✅ AMI verification completed successfully"
                    echo "AMI ID: ${env.AMI_ID}"
                    echo "Name: ${env.SERVICE_NAME}-v${env.SERVICE_VERSION}"
                    echo "=========================================="
                }
            }
        }

        stage('Export AMI Details') {
            steps {
                script {
                    // Create AMI details file for downstream jobs
                    def amiDetails = """
                    [AMI_DETAILS]
                    AMI_ID=${env.AMI_ID}
                    SERVICE_NAME=${env.SERVICE_NAME}
                    SERVICE_VERSION=${env.SERVICE_VERSION}
                    AWS_REGION=${env.AWS_DEFAULT_REGION}
                    BUILD_NUMBER=${env.BUILD_NUMBER}
                    BUILD_URL=${env.BUILD_URL}
                    JOB_NAME=${env.JOB_NAME}
                    """
                    
                    writeFile file: 'ami-details.txt', text: amiDetails
                    
                    // Archive artifacts
                    archiveArtifacts artifacts: 'ami-details.txt', fingerprint: true
                    
                    echo "AMI details exported to ami-details.txt"
                }
            }
        }
    }

    post {
        success {
            script {
                echo "🎉 =========================================="
                echo "🎉 CUSTOM AMI CREATION SUCCESSFUL!"
                echo "🎉 =========================================="
                echo "📋 AMI ID: ${env.AMI_ID}"
                echo "🏷️  Name: ${env.SERVICE_NAME}-v${env.SERVICE_VERSION}"
                echo "🌍 Region: ${env.AWS_DEFAULT_REGION}"
                echo "🔨 Build: ${env.BUILD_NUMBER}"
                echo "📊 Build URL: ${env.BUILD_URL}"
                echo "🎉 =========================================="
                
                // Optional: Send notification
                // slackSend(color: 'good', message: "✅ AMI Built Successfully: ${env.AMI_ID}")
            }
        }
        
        failure {
            script {
                echo "❌ =========================================="
                echo "❌ CUSTOM AMI CREATION FAILED!"
                echo "❌ =========================================="
                echo "Service: ${env.SERVICE_NAME}"
                echo "Build: ${env.BUILD_NUMBER}"
                echo "Please check the logs for details."
                echo "❌ =========================================="
                
                // Optional: Send notification
                // slackSend(color: 'danger', message: "❌ AMI Build Failed: ${env.SERVICE_NAME}")
            }
        }
        
        always {
            script {
                // Clean up workspace if enabled
                if (env.CLEAN_WORKSPACE == 'true') {
                    cleanWs()
                }
                
                // Print end time
                echo "Pipeline completed at: ${new Date()}"
            }
        }
        
        // Cleanup after build
        cleanup {
            cleanWs()
        }
    }
}