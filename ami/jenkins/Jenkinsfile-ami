pipeline {
    agent any

    environment {
        AWS_ACCESS_KEY_ID     = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
    }

    stages {
        stage('Build AMI') {
            steps {
                dir('ami/packer') {
                    sh """
                        packer init ami.pkr.hcl
                        packer build ami.pkr.hcl
                    """
                }
            }
        }
    }
}