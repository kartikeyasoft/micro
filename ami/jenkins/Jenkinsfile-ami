@Library('jenkins-shared-lib-deno@main') _

pipeline {
    agent any

    environment {
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        SERVICE_NAME = 'ami'
        SERVICE_VERSION = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Load Configuration') {
            steps {
                script {
                    def config = envConfig()
                    env.AWS_DEFAULT_REGION = config.aws.region
                    env.BASE_AMI_ID = config.baseAmi.ubuntu2204
                }
            }
        }

        stage('Checkout') {
            steps {
                git url: 'https://github.com/kartikeyasoft/micro.git', branch: 'main'
            }
        }
       
        stage('Create Custom AMI') {
            steps {
                script {
                    dir('ami/packer') {
                        sh """
                            packer init ami.pkr.hcl
                            packer validate ami.pkr.hcl
                            packer build \
                                -var "service_version=${env.SERVICE_VERSION}" \
                                -var "service_name=${env.SERVICE_NAME}" \
                                -var "source_ami=${env.BASE_AMI_ID}" \
                                ami.pkr.hcl | tee build-output.txt
                            
                            AMI_ID=\$(grep -Eo 'ami-[a-f0-9]{8,}' build-output.txt | tail -1)
                            echo "CUSTOM_AMI_ID=\$AMI_ID" > custom-ami.properties
                        """
                        
                        def amiProps = readFile('custom-ami.properties')
                        env.AMI_ID = amiProps.split('=')[1].trim()
                    }
                }
            }
        }
        
        stage('Tag AMI') {
            steps {
                sh """
                    aws ec2 create-tags \
                        --resources ${env.AMI_ID} \
                        --region ${env.AWS_DEFAULT_REGION} \
                        --tags \
                            Key=Name,Value=${env.SERVICE_NAME}-${env.SERVICE_VERSION} \
                            Key=Service,Value=${env.SERVICE_NAME} \
                            Key=Version,Value=${env.SERVICE_VERSION} \
                            Key=BuildNumber,Value=${env.BUILD_NUMBER} \
                            Key=SourceAmi,Value=${env.BASE_AMI_ID}
                """
            }
        }
    }

    post {
        success {
            echo "✅ Custom AMI created: ${env.AMI_ID}"
        }
        failure {
            echo "❌ Custom AMI creation failed!"
        }
    }
}