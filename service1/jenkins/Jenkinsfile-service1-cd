stage('Validate') {
    steps {
        script {
            if (params.ACTION == 'apply') {
                if (!params.AMI_ID || params.AMI_ID == '') {
                    error "AMI_ID is required for apply action"
                }
                // Only validate EUREKA_IP if it's provided (for manual runs)
                // In orchestrator, it will be provided
                if (!params.EUREKA_IP || params.EUREKA_IP == '') {
                    echo "⚠️ Warning: EUREKA_IP not provided. Service1 may not register correctly."
                    echo "Continuing with deployment, but service won't register with Eureka."
                    // Don't error, just warn
                }
            }
        }
    }
}