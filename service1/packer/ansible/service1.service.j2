[Unit]
Description=Service1 - Quiz Application Backend
After=network.target

[Service]
User={{ app_user }}
WorkingDirectory=/opt/{{ app_name }}
Environment="SERVER_PORT={{ service_port }}"
Environment="DB_URL=jdbc:mysql://{{ db_host }}:{{ db_port }}/{{ db_name }}?useSSL=false&serverTimezone=UTC"
Environment="DB_USER={{ db_username }}"
Environment="DB_PASSWORD={{ db_password }}"
Environment="EUREKA_URL=http://{{ eureka_ip }}:{{ eureka_port }}/eureka/"
ExecStart=/usr/bin/java -jar /opt/{{ app_name }}/{{ app_name }}.jar
SuccessExitStatus=143
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target