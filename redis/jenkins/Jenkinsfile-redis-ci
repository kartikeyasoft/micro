@Library('jenkins-shared-lib-deno@main') _

pipeline {
    agent any

    tools {
        maven 'Maven-3.8'
        jdk 'JDK-17'
    }

    environment {
        PATH = "/usr/bin:${env.PATH}"
        NEXUS_URL = 'http://172.21.12.151:8081/repository/maven-releases'
        NEXUS_CREDS = credentials('nexus-creds')
        SERVICE_NAME = 'redis-service'
        AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
        AWS_DEFAULT_REGION = 'us-east-1'
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/kartikeyasoft/micro.git', branch: 'main'
            }
        }

        stage('Set Version') {
            steps {
                dir('redis') {
                    script {
                        env.SERVICE_VERSION = sh(script: 'mvn help:evaluate -Dexpression=project.version -q -DforceStdout', returnStdout: true).trim()
                        echo "Building version: ${env.SERVICE_VERSION}"
                    }
                }
            }
        }

        stage('Maven Compile') {
            steps {
                dir('redis') {
                    sh 'mvn clean compile -Dmaven.test.skip=true'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('redis') {
                    withSonarQubeEnv('sonar') {
                        sh """
                            mvn sonar:sonar \
                                -Dsonar.projectKey=com.ksapp:redis-service \
                                -Dsonar.projectName="Redis_Service_v${env.SERVICE_VERSION}" \
                                -Dsonar.projectVersion=${env.SERVICE_VERSION} \
                                -Dsonar.sources=src/main/java \
                                -Dsonar.java.binaries=target/classes
                        """
                    }
                }
            }
        }

        stage('Maven Package') {
            steps {
                dir('redis') {
                    sh 'mvn package -Dmaven.test.skip=true'
                }
            }
        }

        stage('Deploy to Nexus') {
            steps {
                dir('redis') {
                    script {
                        def jarFile = "target/redis-service-${env.SERVICE_VERSION}.jar"
                        def nexusPath = "${env.NEXUS_URL}/com/ksapp/redis-service/${env.SERVICE_VERSION}/redis-service-${env.SERVICE_VERSION}.jar"
                        
                        // Check if JAR exists
                        sh """
                            if [ ! -f "${jarFile}" ]; then
                                echo "ERROR: JAR file not found: ${jarFile}"
                                exit 1
                            fi
                            echo "Uploading ${jarFile} to ${nexusPath}"
                            curl -f -v -u ${env.NEXUS_CREDS} --upload-file ${jarFile} ${nexusPath}
                        """
                    }
                }
            }
        }

        stage('Bake Golden Image') {
            steps {
                script {
                    withEnv([
                        "SERVICE_VERSION=${env.SERVICE_VERSION}",
                        "SERVICE_NAME=${env.SERVICE_NAME}",
                        "NEXUS_URL=${env.NEXUS_URL}"
                    ]) {
                        dir('redis/packer') {
                            script {
                                // Run packer build and capture exit code
                                def packerExit = sh(script: '''
                                    packer init redis.pkr.hcl
                                    packer build \
                                        -var "service_version=${SERVICE_VERSION}" \
                                        -var "service_name=${SERVICE_NAME}" \
                                        -var "nexus_url=${NEXUS_URL}" \
                                        redis.pkr.hcl 2>&1 | tee build-output.txt
                                    
                                    # Check if packer build failed
                                    if grep -q "Build 'amazon-ebs.redis' errored" build-output.txt; then
                                        echo "Packer build failed"
                                        exit 1
                                    fi
                                    
                                    # Extract AMI ID
                                    AMI_ID=$(grep -oE 'ami-[a-f0-9]{17}' build-output.txt | tail -1)
                                    
                                    # Validate AMI ID is not empty
                                    if [ -z "$AMI_ID" ]; then
                                        echo "ERROR: No AMI ID found in packer output"
                                        exit 1
                                    fi
                                    
                                    # Validate AMI ID is not the base Ubuntu AMI
                                    if [ "$AMI_ID" == "ami-0c7217cdde317cfec" ]; then
                                        echo "ERROR: Base Ubuntu AMI detected - application was not properly installed"
                                        exit 1
                                    fi
                                    
                                    echo "GOLDEN_AMI_ID=$AMI_ID" > golden-ami.properties
                                    echo "Successfully created AMI: $AMI_ID"
                                ''', returnStatus: true)
                                
                                if (packerExit != 0) {
                                    error "Packer build failed. Check logs above for details."
                                }
                            }
                            
                            script {
                                def amiProps = readFile('golden-ami.properties')
                                env.AMI_ID = amiProps.split('=')[1].trim()
                                
                                // Final validation
                                if (!env.AMI_ID || env.AMI_ID == '' || env.AMI_ID == 'ami-0c7217cdde317cfec') {
                                    error "Invalid AMI ID: ${env.AMI_ID}"
                                }
                                
                                echo "✅ Valid AMI ID captured: ${env.AMI_ID}"
                            }
                            stash name: 'redis-ami', includes: 'golden-ami.properties'
                        }
                    }
                }
            }
        }

        stage('Verify JAR in AMI') {
            steps {
                script {
                    echo "=========================================="
                    echo "Verifying AMI ${env.AMI_ID} is valid"
                    echo "=========================================="
                    
                    // You can add a test launch here if needed
                    def amiCheck = sh(script: """
                        aws ec2 describe-images \
                            --region us-east-1 \
                            --image-ids ${env.AMI_ID} \
                            --query 'Images[0].Name' \
                            --output text
                    """, returnStdout: true).trim()
                    
                    if (amiCheck == "None" || amiCheck == "") {
                        error "AMI ${env.AMI_ID} not found or invalid"
                    }
                    
                    echo "AMI Name: ${amiCheck}"
                    
                    if (amiCheck == "myapp-redis-service-v${env.SERVICE_VERSION}") {
                        echo "✅ AMI name matches expected pattern"
                    } else {
                        error "AMI name '${amiCheck}' does not match expected 'myapp-redis-service-v${env.SERVICE_VERSION}'"
                    }
                }
            }
        }

        stage('Trigger CD Pipeline') {
            steps {
                script {
                    echo "=========================================="
                    echo "Triggering CD Pipeline"
                    echo "=========================================="
                    echo "Version: ${env.SERVICE_VERSION}"
                    echo "AMI ID: ${env.AMI_ID}"
                    echo "=========================================="
                    
                    if (env.AMI_ID && env.AMI_ID != '' && env.AMI_ID =~ /^ami-[a-f0-9]{17}$/ && env.AMI_ID != 'ami-0c7217cdde317cfec') {
                        echo "✅ Valid AMI ID, triggering CD pipeline..."
                        
                        build job: 'redis-cd',
                            parameters: [
                                string(name: 'AMI_ID', value: env.AMI_ID),
                                string(name: 'ACTION', value: 'apply')
                            ],
                            wait: false
                        
                        echo "✅ CD pipeline triggered successfully!"
                    } else {
                        error "❌ Invalid AMI ID: ${env.AMI_ID}. CD pipeline will not be triggered."
                    }
                }
            }
        }
    }

    post {
        success {
            echo "🎉 Redis CI completed successfully! AMI: ${env.AMI_ID}"
        }
        failure {
            echo "❌ Redis CI failed!"
        }
    }
}
